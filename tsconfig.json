{
  "compilerOptions": {
    "jsx": "react",
    "module": "esnext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["vite/client"]  
  },
  "include": ["src"]
}
